{
  "name": "@kb-labs/cli-runtime",
  "version": "2.3.0",
  "description": "CLI runtime — command execution, middleware, formatters, presenters, gateway, lifecycle",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./gateway": {
      "types": "./dist/gateway/index.d.ts",
      "default": "./dist/gateway/index.js"
    },
    "./v3": {
      "types": "./dist/v3/index.d.ts",
      "default": "./dist/v3/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@kb-labs/cli-contracts": "workspace:*",
    "@kb-labs/core-contracts": "link:../../../kb-labs-core/packages/core-contracts",
    "@kb-labs/core-platform": "link:../../../kb-labs-core/packages/core-platform",
    "@kb-labs/core-runtime": "link:../../../kb-labs-core/packages/core-runtime",
    "@kb-labs/core-sys": "link:../../../kb-labs-core/packages/core-sys",
    "@kb-labs/plugin-contracts": "link:../../../../infra/kb-labs-plugin/packages/plugin-contracts",
    "@kb-labs/plugin-runtime": "link:../../../../infra/kb-labs-plugin/packages/plugin-runtime",
    "@kb-labs/plugin-execution-factory": "link:../../../../infra/kb-labs-plugin/packages/plugin-execution-factory",
    "cli-table3": "^0.6.5",
    "colorette": "^2.0.20",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@kb-labs/devkit": "link:../../../../infra/kb-labs-devkit",
    "@types/node": "^24.3.3",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
